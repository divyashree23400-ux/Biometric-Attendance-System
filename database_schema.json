{
  "firestore_collections": {
    "students": {
      "description": "Master list of all registered students",
      "document_id": "studentId (e.g. STU001)",
      "fields": {
        "studentId": { "type": "string", "example": "STU001", "description": "Unique student identifier" },
        "name":      { "type": "string", "example": "Rahul Sharma", "description": "Full name of student" },
        "rollNo":    { "type": "string", "example": "22CS101", "description": "College roll number" },
        "branch":    { "type": "string", "example": "Computer Science", "description": "Branch / department" },
        "year":      { "type": "number", "example": 3, "description": "Current year of study" },
        "fingerprintId": { "type": "number", "example": 1, "description": "ID stored on R307 sensor (1–127)" },
        "createdAt": { "type": "timestamp", "example": "2026-07-01T09:00:00Z", "description": "Record creation time" }
      }
    },

    "attendance": {
      "description": "Every attendance punch recorded by the ESP32 terminal",
      "document_id": "Auto-generated by Firestore",
      "fields": {
        "studentId": { "type": "string",    "example": "STU001",      "description": "Foreign key → students collection" },
        "name":      { "type": "string",    "example": "Rahul Sharma", "description": "Denormalised for fast queries" },
        "date":      { "type": "string",    "example": "2026-07-01",  "description": "Date of punch (YYYY-MM-DD)" },
        "time":      { "type": "string",    "example": "09:32:00",    "description": "Time of punch (HH:MM:SS, 24hr)" },
        "status":    { "type": "string",    "example": "Present",     "description": "Present | Absent | Late" },
        "deviceId":  { "type": "string",    "example": "ESP32-LAB-01","description": "Which terminal recorded the punch" },
        "synced":    { "type": "boolean",   "example": true,          "description": "False if pushed from offline queue" },
        "timestamp": { "type": "timestamp", "example": "2026-07-01T09:32:00Z", "description": "Full ISO timestamp for sorting" }
      }
    }
  },

  "collection_diagram": {
    "students  (collection)": {
      "STU001  (document)": {
        "studentId": "STU001",
        "name": "Rahul Sharma",
        "rollNo": "22CS101",
        "branch": "Computer Science",
        "year": 3,
        "fingerprintId": 1
      }
    },
    "attendance  (collection)": {
      "auto-id-001  (document)": {
        "studentId": "STU001",
        "name": "Rahul Sharma",
        "date": "2026-07-01",
        "time": "09:32:00",
        "status": "Present",
        "deviceId": "ESP32-LAB-01",
        "synced": true,
        "timestamp": "2026-07-01T09:32:00Z"
      }
    }
  }
}
